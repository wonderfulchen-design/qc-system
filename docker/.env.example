# 环境变量配置示例
# 复制此文件为 .env 并修改实际值

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=QcSystem2025!@#
MYSQL_PASSWORD=QcUser2025!@#
MYSQL_PORT=3306

# ==================== JWT 配置 ====================
# 生产环境务必修改为随机字符串！
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-$(openssl rand -hex 32)
ACCESS_TOKEN_EXPIRE_DAYS=1

# ==================== 端口配置 ====================
API_PORT=8000
HTTP_PORT=80
HTTPS_PORT=443

# ==================== 爬虫配置 ====================
CRAWLER_BASE_URL=http://114.55.34.212:8080
CRAWLER_ENABLED=true

# ==================== 企业微信配置 (可选) ====================
